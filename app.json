{
  "expo": {
    "name": "Splitr",
    "slug": "splitrai",
    "version": "1.1.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "splitr",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d9488"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.splitrtest.ai",
      "buildNumber": "1",
      "associatedDomains": [
        "applinks:splitr.ai",
        "applinks:splitr.ai"
      ],
      "infoPlist": {
        "NSFaceIDUsageDescription": "Splitr uses Face ID to securely unlock the app.",
        "NSCameraUsageDescription": "Splitr needs camera access to scan receipts.",
        "NSPhotoLibraryUsageDescription": "Splitr needs photo library access to select receipt images.",
        "NSContactsUsageDescription": "Splitr uses your contacts to find friends already on the app and send invites.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0d9488"
      },
      "package": "com.splitr.ai",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_CONTACTS",
        "android.permission.RECORD_AUDIO",
        "android.permission.WRITE_CONTACTS"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "splitr.ai",
              "pathPrefix": "/invite"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Splitr to access your camera to scan receipts."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Splitr to access your photos to select receipt images."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#0d9488",
          "defaultChannel": "default",
          "enableBackgroundRemoteNotifications": true
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-image",
      "expo-web-browser",
      [
        "expo-contacts",
        {
          "contactsPermission": "Allow Splitr to access your contacts to find friends and send invites."
        }
      ],
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "51e5bbb4-f40e-4420-ab54-6bcd761ac6f6"
      }
    }
  }
}
